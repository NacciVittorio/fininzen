# Production-style container reference.
# Copy to `.env` and replace the placeholders before running the stack.

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key-at-least-50-chars
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=fininzen
POSTGRES_USER=fininzen
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
FIELD_ENCRYPTION_KEYS=CHANGE_ME_BASE64_32_BYTE_KEY
REDIS_URL=redis://redis:6379/0

# Optional for browser-facing deployments behind a reverse proxy.
CSRF_TRUSTED_ORIGINS=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Fininzen
WEBAUTHN_ORIGIN=http://localhost:8000
