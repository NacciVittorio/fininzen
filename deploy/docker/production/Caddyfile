# Full-stack reverse proxy — plain HTTP on :80 (of the container), temporarily
# published on an alternate host port (HTTP_PORT) instead of the real 80/443,
# because this VPS's host already runs a separate systemd Caddy on those for
# another domain (finnet.nacci.eu). That host Caddy gets the Let's Encrypt
# certificate for fininzen.nacci.eu and relays to this container:
#
#   fininzen.nacci.eu {
#       reverse_proxy 127.0.0.1:<HTTP_PORT>
#   }
#
# added as an extra site block in its own Caddyfile (e.g. /etc/caddy/Caddyfile),
# then `systemctl reload caddy`. See wiki/VPS_DEPLOY_CHECKLIST.md.
#
# When that host Caddy is eventually retired, flip this block back to
# `fininzen.nacci.eu {` (auto-TLS), set HTTP_PORT=80, and add `443:443` to the
# `caddy` service's ports in ./compose.yml — no other changes needed.
:80 {
	encode gzip

	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Django's collected static assets (admin + DRF browsable API). handle_path
	# strips the /static prefix so the path maps directly into the volume root.
	handle_path /static/* {
		root * /srv/staticfiles
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Browser-visible API path. Strip ONLY the /fininzen segment so Django still
	# receives /api/* — `handle_path /fininzen/api/*` would strip the whole
	# /fininzen/api prefix and Django would see /auth/... → 404 on every call.
	handle /fininzen/api/* {
		uri strip_prefix /fininzen
		reverse_proxy backend:8000
	}

	# Legacy unprefixed API, kept reachable for direct callers.
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Everything else → the Next.js server (SPA + SSR).
	handle {
		reverse_proxy frontend:3000
	}
}
