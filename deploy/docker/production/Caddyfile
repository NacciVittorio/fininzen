# Reference snippet — NOT consumed by docker compose.
#
# This VPS already runs a system-wide, systemd-managed Caddy bound to the
# host's :80/:443 (serving finnet.nacci.eu). A second Caddy trying to bind
# those same ports from inside docker compose would fail to start
# ("address already in use"). So the Docker stack here only runs
# Postgres/Redis/Django/Next.js, publishing backend/frontend on 127.0.0.1
# (see ../production/compose.yml), and this block is added instead as a new
# site to the HOST's own Caddyfile (typically /etc/caddy/Caddyfile),
# alongside the existing finnet.nacci.eu block. After editing it there:
#   systemctl reload caddy
#
# Ports below (8010/3010) must match BACKEND_PORT/FRONTEND_PORT in
# deploy/docker/production/.env (defaults shown here).
fininzen.nacci.eu {
	log {
		output file /var/log/caddy_fininzen_access.log
	}
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Django's collected static assets (admin + DRF browsable API). handle_path
	# strips the /static prefix so the path maps directly into the folder root.
	# Must match the bind-mount host path in compose.yml (../../../staticfiles
	# resolved from /opt/fininzen).
	handle_path /static/* {
		root * /opt/fininzen/staticfiles
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Browser-visible API path. Strip ONLY the /fininzen segment so Django still
	# receives /api/* — `handle_path /fininzen/api/*` would strip the whole
	# /fininzen/api prefix and Django would see /auth/... → 404 on every call.
	handle /fininzen/api/* {
		uri strip_prefix /fininzen
		reverse_proxy 127.0.0.1:8010
	}

	# Legacy unprefixed API, kept reachable for direct callers.
	handle /api/* {
		reverse_proxy 127.0.0.1:8010
	}

	# Everything else → the Next.js server (SPA + SSR).
	handle {
		reverse_proxy 127.0.0.1:3010
	}
}
