# Full Docker stack — copy to `.env` in this directory and fill in real values.
#   cp deploy/docker/production/.env.example deploy/docker/production/.env
# NEVER commit the resulting .env.

# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_DEBUG=0
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_random_at_least_50_chars
# CSV of hostnames the app answers on. MUST include the VM's LAN IP (how you
# reach it from a browser) and `backend` (how the Next.js SSR layer reaches
# Django over the compose network). 127.0.0.1/localhost are added automatically.
DJANGO_ALLOWED_HOSTS=backend,localhost,127.0.0.1,CHANGE_ME_VM_IP

# ── Plain-HTTP LAN deploy (no TLS) ───────────────────────────────────────────
# Leave these at 0 while serving over http://<VM-IP>. Behind a real domain +
# HTTPS, set both to 1 (and switch the Caddyfile site address to your domain).
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_COOKIES=0

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=fininzen
POSTGRES_USER=fininzen
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# ── Redis (shared throttle/cache backend) ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Field-level encryption (REQUIRED) ────────────────────────────────────────
# Comma-separated base64 32-byte keys; first encrypts, rest decrypt on rotation.
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEYS=CHANGE_ME_BASE64_32_BYTE_KEY

# ── Browser path / CSRF ──────────────────────────────────────────────────────
REFRESH_COOKIE_PATH=/fininzen/api/auth/
# Add your access origin so Django trusts cross-checked POSTs. Use the VM IP.
CSRF_TRUSTED_ORIGINS=http://CHANGE_ME_VM_IP

# ── WebAuthn / passkeys ──────────────────────────────────────────────────────
# Passkeys only work over HTTPS or on localhost. Over http://<VM-IP> from
# another machine they will NOT work — username+password login still does.
WEBAUTHN_RP_ID=CHANGE_ME_VM_IP
WEBAUTHN_RP_NAME=Fininzen
WEBAUTHN_ORIGIN=http://CHANGE_ME_VM_IP

# ── Optional ─────────────────────────────────────────────────────────────────
# Loopback-only host ports for backend/frontend (the host's own system Caddy
# reverse-proxies to these — see ./Caddyfile). Must match its config.
# BACKEND_PORT=8010
# FRONTEND_PORT=3010
