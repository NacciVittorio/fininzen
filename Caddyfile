finnet.nacci.eu {
	# Log per il debug (opzionale ma utile)
	log {
		output file /var/log/caddy_access.log
	}
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Edge rate-limiting for the auth surface is handled by fail2ban parsing this
	# access log (see deploy/fail2ban/), as defense-in-depth in front of the DRF
	# ScopedRateThrottle. We deliberately do NOT use Caddy's community rate_limit
	# module so the stock Caddy binary stays sufficient — one fewer moving part.

	handle /static/* {
		root * /opt/finnet/staticfiles
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle /api/* {
		reverse_proxy localhost:8000
	}

	handle {
		root * /opt/finnet/frontend/dist
		@frontendAssets path /assets/*
		header @frontendAssets Cache-Control "public, max-age=31536000, immutable"
		@frontendShell not path /assets/*
		header @frontendShell Cache-Control "no-cache, must-revalidate"
		try_files {path} /index.html
		file_server
	}
}
