fininzen.nacci.eu {
	# Log per il debug (opzionale ma utile)
	log {
		output file /var/log/caddy_access.log
	}
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Edge rate-limiting for the auth surface is handled by fail2ban parsing this
	# access log (see deploy/fail2ban/), as defense-in-depth in front of the DRF
	# ScopedRateThrottle. We deliberately do NOT use Caddy's community rate_limit
	# module so the stock Caddy binary stays sufficient — one fewer moving part.

	handle /static/* {
		root * /opt/fininzen/staticfiles
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# ── Phase 2 (Next.js) cutover ──
	# The SPA now lives in the Next.js app (web/, `next start` on :3000, see
	# deploy/systemd/fininzen-web.service). It calls the API under the
	# `/fininzen/api/*` prefix; `handle_path` strips `/fininzen` so Django still
	# receives `/api/*` unchanged. Django must run with
	# REFRESH_COOKIE_PATH=/fininzen/api/auth/ so the fn_refresh cookie is scoped
	# to the browser-visible path (set it in /etc/fininzen.env at cutover).
	handle_path /fininzen/api/* {
		reverse_proxy localhost:8000
	}

	# Legacy unprefixed API kept reachable during the cutover window; can be
	# removed once nothing calls /api/* directly.
	handle /api/* {
		reverse_proxy localhost:8000
	}

	# Everything else → the Next.js Node server (serves the SPA + SSR).
	handle {
		reverse_proxy localhost:3000
	}
}
