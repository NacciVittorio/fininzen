# Production environment variables — copy to .env and fill in real values
# NEVER commit .env with real secrets

# Django
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key-at-least-50-chars
DJANGO_ALLOWED_HOSTS=fininzen.nacci.eu

# CORS & CSRF
CORS_ALLOWED_ORIGINS=https://fininzen.nacci.eu
CSRF_TRUSTED_ORIGINS=https://fininzen.nacci.eu

# WebAuthn (Face ID / Touch ID app-lock). RP_ID must equal the host exactly;
# ORIGIN is the full scheme+host. Without these the localhost defaults break
# biometrics on the real domain.
WEBAUTHN_RP_ID=fininzen.nacci.eu
WEBAUTHN_RP_NAME=Fininzen
WEBAUTHN_ORIGIN=https://fininzen.nacci.eu

# Caddy serves the browser the prefixed /fininzen/api/auth/* path, so Django must
# scope the fn_refresh cookie to that exact path or silent token refresh breaks
# (the browser never re-sends it). The Docker stack sets this automatically.
REFRESH_COOKIE_PATH=/fininzen/api/auth/

# Database — SQLite di default (nessuna variabile richiesta). Adatto a VPS piccole
# (1 vCPU / 1 GB RAM): SQLite in WAL è un solo file, zero processo/RAM extra.
#
# Per usare SQLite in PRODUZIONE (DEBUG=0) imposta esplicitamente questo opt-in,
# altrimenti l'app rifiuta il boot (rete di sicurezza contro un SQLite accidentale):
ALLOW_SQLITE_IN_PRODUCTION=1
# Percorso del file SQLite (default: <repo>/db.sqlite3). Sul VPS di solito:
DB_PATH=/opt/fininzen/db.sqlite3
#
# --- Postgres (opzionale, non usato di default; stack Docker conservato come
# --- riferimento futuro). Impostando una di queste variabili l'app passa a
# --- Postgres e ALLOW_SQLITE_IN_PRODUCTION diventa irrilevante.
# DATABASE_URL=postgres://fininzen:CHANGE_ME@127.0.0.1:5432/fininzen?sslmode=disable
# POSTGRES_DB=fininzen
# POSTGRES_USER=fininzen
# POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=require
# DB_CONN_MAX_AGE=60

# Field-level encryption (AES-256-GCM) — REQUIRED in production. Comma-separated
# base64 32-byte keys; the first encrypts, the rest are kept for decryption during
# rotation. The app refuses to boot in production without at least one key.
# Generate one with:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEYS=CHANGE_ME_BASE64_32_BYTE_KEY

# Backup-at-rest encryption (optional but recommended). When set,
# scripts/backup_db.sh encrypts the pg_dump with AES-256 before storing it (and
# the off-site replica ships the encrypted file).
# BACKUP_ENC_PASSPHRASE=CHANGE_ME_LONG_RANDOM_PASSPHRASE

# Throttling backend (HIGH-20). DRF ScopedRateThrottle uses Django's cache; the
# default LocMemCache is per-process, so with 2+ gunicorn workers each keeps its
# own bucket and the effective limit is N×configured. Point this at a shared
# Redis so rate limits are enforced across workers.
REDIS_URL=redis://127.0.0.1:6379/0

# Error tracking (HIGH-35). Opt-in: leave unset to disable (no-op in dev/test).
# When set, the backend initialises Sentry (sentry-sdk, already in requirements);
# send_default_pii stays False so financial request bodies aren't shipped.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0

# Off-site backup replication (CRIT-08) — opzionale ma raccomandato in prod.
# Lascia vuoto per disabilitare; usato da scripts/backup_offsite.sh (vedi
# wiki/DOCKER_DEPLOY.md §8).
# OFFSITE_RSYNC_TARGET=fininzen-backup@altro.vps.example:/srv/fininzen-backups/
# OFFSITE_RSYNC_OPTS=--archive --compress --delete-after --bwlimit=2M
# OFFSITE_ALERT_EMAIL=ops@example.com
